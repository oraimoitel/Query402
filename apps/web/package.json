{
  "name": "@query402/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prebuild": "npm --prefix ../../packages/shared run build",
    "pretypecheck": "npm --prefix ../../packages/shared run build",
    "dev": "vite",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src vite.config.ts",
    "format": "prettier --write src vite.config.ts tailwind.config.ts",
    "format:check": "prettier --check src vite.config.ts tailwind.config.ts"
  },
  "dependencies": {
    "@query402/shared": "0.1.0",
    "@stellar/freighter-api": "^6.0.1",
    "@x402/core": "^2.9.0",
    "@x402/fetch": "^2.9.0",
    "@x402/stellar": "^2.9.0",
    "lucide-react": "^0.511.0",
    "ogl": "^1.0.11",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.3"
  },
  "devDependencies": {
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^5.4.19"
  }
}
